# ───────────────────────────────────────────────────────────
# IDEA — Environment template
# Copy to `.env` and fill in real values. NEVER commit `.env`.
# ───────────────────────────────────────────────────────────

# ── PostgreSQL ──
POSTGRES_DB=idea_db
POSTGRES_USER=idea_user
POSTGRES_PASSWORD=change_me_in_local_env
POSTGRES_PORT=5432

# ── Redis ──
REDIS_PORT=6379

# ── Backend (Spring Boot) ──
BACKEND_PORT=8080
# JWT secret — generate a strong random value per environment
JWT_SECRET=change_me_with_a_long_random_secret
JWT_ACCESS_EXPIRATION_MINUTES=30
JWT_REFRESH_EXPIRATION_DAYS=7

# ── Frontend (Vite) ──
FRONTEND_PORT=5173
VITE_API_BASE_URL=http://localhost:8080/api
