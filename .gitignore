# ───────────────────────────────────────────────────────────
# IDEA — Root .gitignore
# Keep secrets, build artifacts and local tooling OUT of git.
# ───────────────────────────────────────────────────────────

# Environment & secrets (NEVER commit real credentials)
.env
.env.local
.env.*.local
*.pem
*.key

# OS noise
.DS_Store
Thumbs.db

# IDE / editor
.idea/
.vscode/
*.iml
*.swp

# Logs
*.log
logs/

# ── Backend (Java / Maven / Spring Boot) ──
backend/target/
backend/.mvn/wrapper/maven-wrapper.jar
backend/build/
*.class

# ── Frontend (Node / React / Vite) ──
frontend/node_modules/
frontend/dist/
frontend/.vite/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Docker ──
# (compose files ARE tracked; runtime data is not)
**/docker-volumes/

# ── Database dumps ──
*.sql.bak
*.dump
